{
  "profile": "elmesdolc",
  "background_removal": {
    "model": "birefnet-massive",
    "alpha_matting": false,
    "alpha_matting_foreground_threshold": 240,
    "alpha_matting_background_threshold": 10,
    "alpha_matting_erode_size": 10,
    "keep_largest_component": true
  },
  "formats": {
    "catalogo": {
      "width": 1600,
      "height": 1600,
      "format": "JPEG",
      "quality": 95,
      "background_color": "#FFFFFF",
      "product_margin_pct": 0.10
    }
  },
  "overlay": {
    "font_path": "C:\\Windows\\Fonts\\arialbd.ttf",
    "elements": {
      "product_name": {
        "position": "bottom-left",
        "font_size": 44,
        "text_color": "#D4AF37",
        "margin": 45
      }
    },
    "text_background": {
      "enabled": true,
      "color": "#16213B",
      "opacity": 0.92,
      "padding": 22,
      "border_color": "#D4AF37",
      "border_width": 3
    },
    "logo": {
      "enabled": true,
      "path": "configs/assets/elmesdolc_logo.png",
      "position": "top-right",
      "margin": 40,
      "max_width_pct": 0.2
    }
  }
