{
  "profile": "instagram",
  "background_removal": {
    "model": "birefnet-massive",
    "alpha_matting": false,
    "alpha_matting_foreground_threshold": 240,
    "alpha_matting_background_threshold": 10,
    "alpha_matting_erode_size": 10,
    "keep_largest_component": true
  },
  "formats": {
    "feed": {
      "width": 1600,
      "height": 2000,
      "format": "JPEG",
      "quality": 97,
      "background_color": "#FFFFFF",
      "product_margin_pct": 0.03,
      "max_crop_pct": 0.30,
      "fill_style": "blur",
      "blur_fill": {
        "radius_pct": 0.05,
        "tint_color": "#0F1B2E",
        "tint_opacity": 0.12
      }
    },
    "stories": {
      "width": 1080,
      "height": 1920,
      "format": "JPEG",
      "quality": 97,
      "background_color": "#FFFFFF",
      "product_margin_pct": 0.03,
      "max_crop_pct": 0.22,
      "fill_style": "blur",
      "blur_fill": {
        "radius_pct": 0.06,
        "tint_color": "#0F1B2E",
        "tint_opacity": 0.18
      }
    }
  },
  "overlay": {
    "font_path": "assets/fonts/PlayfairDisplay-Variable.ttf",
    "font_weight": "Black",
    "elements": {
      "product_name": {
        "position": "bottom-left",
        "font_size": 58,
        "text_color": "#D4AF37",
        "margin": 55
      }
    },
    "text_style": "stroke",
    "text_shadow": {
      "enabled": true,
      "color": "#000000",
      "opacity": 0.55,
      "offset": 5
    },
    "text_stroke": {
      "color": "#0F1B2E",
      "width": 7
    },
    "scrim": {
      "enabled": true,
      "position": "bottom",
      "height_pct": 0.4,
      "color": "#0F1B2E",
      "max_opacity": 0.85
    },
    "logo": {
      "enabled": false,
      "path": "configs/assets/instagram_logo.png",
      "position": "top-right",
      "margin": 35,
      "max_width_pct": 0.09
    }
  }
}
